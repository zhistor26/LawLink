# LawLink 环境变量模板
# 复制为 .env 后填入真实值。.env 不会进 git，绝不提交。

# —— 数据库 ——
# 本地开发（直连 Postgres）：
DATABASE_URL="postgresql://lawlink:lawlink@localhost:5432/lawlink?schema=public"

# Postgres 容器变量（仅 docker compose 用）
POSTGRES_DB=lawlink
POSTGRES_USER=lawlink
POSTGRES_PASSWORD=lawlink
POSTGRES_PORT=5432

# —— 鉴权 ——
# 生成方法：openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_OUTPUT_OF_openssl_rand_base64_32"
NEXTAUTH_URL="http://localhost:3000"

# —— 文件存储与加密 ——
APP_STORAGE_DIR="./storage"
# 文件加密主密钥（AES-256-GCM），base64 编码的 32 字节
# 生成方法：openssl rand -base64 32
# ⚠️ 丢失此密钥则所有加密材料不可恢复，独立于数据库备份
STORAGE_ENCRYPTION_KEY="REPLACE_WITH_OUTPUT_OF_openssl_rand_base64_32"

# —— 云存储（可选，v0.17）——
# 切到 s3 时所有后续 writeFile 都写 S3；已写的 local 文件不会自动迁移
# STORAGE_PROVIDER="local"     # 默认 local；改为 "s3" 启用云存储
# AWS_REGION="ap-northeast-1"
# S3_BUCKET="lawlink-storage"
# AWS_ACCESS_KEY_ID=""
# AWS_SECRET_ACCESS_KEY=""
# S3_ENDPOINT=""               # 可选，自建 S3 兼容（MinIO / R2 / 阿里云 OSS 兼容端点）
# S3_FORCE_PATH_STYLE="false"  # MinIO 必须 true
# S3_KEY_PREFIX="prod/"        # 可选，所有对象 key 前缀

# —— 懒猫微服（LPK 部署时由 manifest 注入，本地勿开）——
# LAZYCAT_AUTH=1

SEED_ADMIN_EMAIL="admin@lawlink.local"
SEED_ADMIN_PASSWORD="ChangeMe!2026"
SEED_ADMIN_NAME="系统管理员"
