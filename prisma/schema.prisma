// LawLink 数据 schema
// 对应 docs/DATA-MODEL.md v0.3
// 修改前先改文档，再改 schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// 枚举
// ============================================================

enum UserRole {
  ADMIN
  PRINCIPAL_LAWYER
  LAWYER
  ASSISTANT
  FINANCE
}

enum MatterCategory {
  CIVIL_COMMERCIAL
  CRIMINAL
  ADMINISTRATIVE
  NON_LITIGATION
  LEGAL_COUNSEL
  SPECIAL_PROJECT
}

enum MatterStatus {
  PENDING_ACCEPTANCE
  IN_PROGRESS
  ON_HOLD
  CLOSED
  ARCHIVED
}

enum MatterMemberRole {
  LEAD
  CO_LEAD
  ASSISTANT
}

enum IntakeStatus {
  INTAKE
  PENDING_CONFIRMATION
  CONVERTED
  DECLINED // 最终拒绝（无法补正）
  NEEDS_REVISION // 待补正（可由律师补充材料后重新提交审批）
}

enum LitigationStanding {
  PLAINTIFF
  DEFENDANT
  THIRD_PARTY
  COUNTERCLAIM_PLAINTIFF
  COUNTERCLAIM_DEFENDANT
  // v0.5: 二审 / 再审 / 执行
  APPELLANT
  APPELLEE
  RETRIAL_APPLICANT
  RETRIAL_RESPONDENT
  ENFORCEMENT_APPLICANT
  EXECUTED_PERSON
  // 刑事
  CRIMINAL_DEFENDANT
  CRIMINAL_VICTIM
  PRIVATE_PROSECUTOR
  CRIMINAL_INCIDENTAL_PLAINTIFF
  // 仲裁
  ARBITRATION_CLAIMANT
  ARBITRATION_RESPONDENT
  // 行政
  ADMIN_PLAINTIFF
  ADMIN_DEFENDANT
  ADMIN_RECONSIDERATION_APPLICANT
  ADMIN_RECONSIDERATION_RESPONDENT
  // 非诉
  NON_LITIGATION_PARTY
}

enum FeeType {
  FIXED // 固定收费
  CONTINGENCY // 风险代理
}

enum InvoiceType {
  PLAIN // 普通发票
  SPECIAL // 增值税专用发票
}

enum InvoiceItem {
  LAWYER_FEE // 律师服务费
  CONSULTING_FEE // 法律咨询费
  AGENCY_FEE // 代理费
  OTHER // 其他法律服务
}

enum InvoiceRequestStatus {
  PENDING // 律师已申请、待财务处理
  APPROVED // 财务已批准、待开票
  ISSUED // 已开具（含电子发票）
  REJECTED // 被拒
}

// v0.10: 文书审批状态
enum DocumentStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  FILED
}

enum ProcedureType {
  // 审判通用
  FIRST_INSTANCE
  SECOND_INSTANCE
  RETRIAL_REVIEW
  RETRIAL
  REMAND_FIRST
  REMAND_SECOND
  PROSECUTORIAL_SUPERVISION
  // 仲裁
  COMMERCIAL_ARBITRATION
  LABOR_ARBITRATION
  ARBITRATION_SET_ASIDE
  ARBITRATION_ENFORCEMENT_REVIEW
  // 执行
  ENFORCEMENT
  ENFORCEMENT_OBJECTION
  // 刑事
  INVESTIGATION
  PROSECUTION_REVIEW
  DEATH_PENALTY_REVIEW
  CRIMINAL_ENFORCEMENT
  COMMUTATION_PAROLE_REVIEW
  // 行政
  ADMIN_RECONSIDERATION
  ADMIN_NON_LITIGATION_ENFORCEMENT
  // 非诉
  NON_LITIGATION_PHASE
  // 兜底
  CUSTOM
}

enum ProcedureStatus {
  PENDING
  IN_PROGRESS
  CONCLUDED
}

enum ProcedureEngagement {
  ENGAGED
  INFORMATIONAL
}

enum ProcedureOutcome {
  WON
  PARTIAL_WON
  LOST
  MEDIATED
  WITHDRAWN
  DISMISSED
  COMPLETED
  TRANSFERRED
  OTHER
}

enum PartyRole {
  CLIENT_PARTY
  OPPOSING_PARTY
  THIRD_PARTY
  CO_LITIGANT
  AGENT
  WITNESS
  OTHER
}

// v0.27: 当事人主体类型（自然人 vs 公司/组织），决定必填校验分支
enum PartyType {
  NATURAL_PERSON
  ORGANIZATION
}

enum ClientType {
  INDIVIDUAL
  COMPANY
  ORGANIZATION
}

enum ConflictSeverity {
  LOW
  MEDIUM
  HIGH
  BLOCKING
}

enum ConflictConclusion {
  PENDING
  SAME_SUBJECT
  DIFFERENT
  NEED_INFO
}

enum DeadlineCategory {
  LIMITATION
  EVIDENCE
  APPEAL
  PERFORMANCE
  RESPONSE
  ENFORCEMENT
  ARBITRATION_SET_ASIDE
  CUSTOM
}

enum NoteChannel {
  PHONE
  WECHAT
  EMAIL
  MEETING
  COURT
  OTHER
}

enum DocumentCategory {
  EVIDENCE
  PLEADING
  PROCEDURE
  JUDGMENT
  CONTRACT
  OTHER
}

enum BillingStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum FeeEntryType {
  RECEIVABLE
  RECEIVED
  REFUND
  COST
  COMMISSION
}

// v0.8: 文档模板分类
enum TemplateCategory {
  INTAKE // 收案文书：收案登记表 / 风险告知书 / 质量反馈卡
  RETAINER // 委托文书：委托代理合同 / 授权委托书
  LITIGATION // 诉讼文书：起诉状 / 答辩状 / 上诉状 / 反诉状 / 仲裁申请书
  HEARING // 庭审文书：谈话笔录 / 庭审笔录 / 阅卷笔录 / 询问笔录
  WORK_PRODUCT // 工作成果：办案小结 / 法律意见书 / 代理意见 / 律师函 / 公函
  ARCHIVE // 卷宗文书：卷宗封皮 / 卷宗目录 / 备考表 / 证据目录
  CLOSING // 结案文书：结案登记表 / 结算单
  BLANK // 空白文档（套律所抬头）
}

// v0.8: 用章种类
enum SealType {
  OFFICIAL_SEAL // 律师事务所公章
  CONTRACT_SEAL // 合同专用章
  FINANCE_SEAL // 财务专用章
  LEGAL_REP_SEAL // 法定代表人章
  CONTRACT_REVIEW_SEAL // 合同审核章
}

// v0.8: 用章申请状态
enum SealRequestStatus {
  PENDING // 待审批
  APPROVED // 已批准，待盖章
  STAMPED // 已盖章并回填扫描件（终态）
  REJECTED // 被驳回（终态，但可新建一条引用此 ID 重新申请）
  CANCELLED // 申请人主动撤销
}

// v0.8: 紧急程度
enum Urgency {
  NORMAL
  URGENT
}

// ============================================================
// 用户与权限
// ============================================================

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(LAWYER)
  phone        String?
  avatar       String?
  active       Boolean   @default(true)
  lastLoginAt  DateTime?

  ownedMatters          Matter[]              @relation("MatterOwner")
  memberships           MatterMember[]
  commissionPlans       CommissionPlan[]
  feeEntriesBeneficiary FeeEntry[]            @relation("FeeBeneficiary")
  feeEntriesRecorded    FeeEntry[]            @relation("FeeRecorder")
  authoredNotes         Note[]                @relation("NoteAuthor")
  uploadedDocuments     Document[]            @relation("DocumentUploader")
  reviewedDocuments     Document[]            @relation("DocumentReviewer")
  approvedDocuments     Document[]            @relation("DocumentApprover")
  auditLogs             AuditLog[]
  conflictDecisions     ConflictCheck[]       @relation("ConflictDecidedBy")
  // v0.5
  ownedIntakes          Intake[]              @relation("IntakeOwner")
  invoiceRequests       InvoiceRequest[]      @relation("InvoiceRequester")
  invoiceProcessing     InvoiceRequest[]      @relation("InvoiceProcessor")
  // v0.8: 模板创建者 + 用章申请人/审批人/盖章人
  createdTemplates      DocumentTemplate[]    @relation("TemplateCreator")
  sealRequests          SealRequest[]         @relation("SealRequester")
  sealApprovals         SealRequest[]         @relation("SealApprover")
  sealStamps            SealRequest[]         @relation("SealStamper")
  // v0.9: 短信收件人 / 保全负责人 / 保全续保操作人 / 快递创建人
  receivedSmsMessages   SmsMessage[]          @relation("SmsReceiver")
  ownedPreservations    Preservation[]        @relation("PreservationOwner")
  preservationRenewals  PreservationRenewal[] @relation("RenewalPerformer")
  createdExpress        ExpressTracking[]     @relation("ExpressCreator")
  // v0.10: 通知
  notifications         Notification[]
  // v0.21: AI 文书审查历史（发起人）
  aiReviews             ReviewRecord[]        @relation("ReviewAuthor")
  // v0.22: 律所资料上传者
  firmFilesUploaded     FirmFile[]            @relation("FirmFileUploader")
  // v0.27: 服务中心 - 公告发布者 / 外部联系人录入者
  publishedAnnouncements Announcement[]       @relation("AnnouncementAuthor")
  createdExternalContacts ExternalContact[]   @relation("ExternalContactCreator")
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
}

// ============================================================
// 客户与联系人
// ============================================================

model Client {
  id          String         @id @default(cuid())
  name        String
  type        ClientType
  idNumber    String?
  address     String?
  phone       String?
  email       String?
  source      String?
  tags        String[]
  notes       String?
  legalRep    String?
  contacts    Contact[]
  intakes     Intake[]
  matterLinks MatterClient[]
  matters     Matter[]
  deletedAt   DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([name])
  @@index([idNumber])
}

model Contact {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  title     String?
  phone     String?
  email     String?
  wechat    String?
  isPrimary Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

// ============================================================
// 案由规范库
// ============================================================

model CauseOfAction {
  id         String          @id @default(cuid())
  category   MatterCategory
  code       String?
  name       String
  shortName  String?
  level      Int
  parentId   String?
  parent     CauseOfAction?  @relation("CauseHierarchy", fields: [parentId], references: [id])
  children   CauseOfAction[] @relation("CauseHierarchy")
  active     Boolean         @default(true)
  pinyin     String?
  keywords   String[]
  matters    Matter[]
  intakes    Intake[]
  sourceNote String?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([category, code])
  @@index([category, level])
  @@index([category, active, level])
  @@index([name])
  @@index([parentId])
}

// ============================================================
// 收案
// ============================================================

model Intake {
  id             String         @id @default(cuid())
  title          String
  category       MatterCategory @default(CIVIL_COMMERCIAL)
  causeId        String?
  cause          CauseOfAction? @relation(fields: [causeId], references: [id])
  causeFreeText  String?
  description    String?
  status         IntakeStatus   @default(INTAKE)
  receivedAt     DateTime       @default(now())
  declinedReason String?

  // v0.5: 客户 + 联系人
  clientId     String?
  client       Client?     @relation(fields: [clientId], references: [id])
  clientType   ClientType? // 提交时自动建档用，转化后随 Client 表
  contactName  String?
  contactPhone String?

  // v0.5: 程序 + 诉讼地位 + 争议解决机构 + 标的
  firstProcedureType ProcedureType?
  firstAgency        String? // 法院/仲裁机构/侦查机关 名称
  ourStanding        LitigationStanding?
  claimAmount        Decimal?            @db.Decimal(14, 2)
  claimDescription   String? // 非金钱标的描述

  // v0.5: 律师费
  feeType          FeeType?
  feeAmount        Decimal? @db.Decimal(14, 2) // FIXED: 总金额；CONTINGENCY: 基础办案费
  contingencyTerms String? // 风险代理收费方式自由文本（仅 CONTINGENCY 用）
  feeSchedule      String? // 付款节点
  feeNote          String?

  // v0.5: 主办律师 + 共同律师（转化时生成 MatterMember）
  ownerUserId String?
  ownerUser   User?    @relation("IntakeOwner", fields: [ownerUserId], references: [id])
  coUserIds   String[] @default([])

  parties        Party[]
  conflictChecks ConflictCheck[]
  matter         Matter?
  documents      Document[]

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, receivedAt])
  @@index([causeId])
  @@index([ownerUserId])
}

// ============================================================
// 案件 (Matter) + 团队成员 + 多客户
// ============================================================

model Matter {
  id           String         @id @default(cuid())
  internalCode String         @unique
  title        String
  category     MatterCategory @default(CIVIL_COMMERCIAL)
  status       MatterStatus   @default(IN_PROGRESS)

  causeId       String?
  cause         CauseOfAction? @relation(fields: [causeId], references: [id])
  causeFreeText String?

  claimAmount Decimal? @db.Decimal(14, 2)

  ourStanding             LitigationStanding?
  counterclaimAsPlaintiff Boolean             @default(false)
  counterclaimAsDefendant Boolean             @default(false)

  intakeDate DateTime?

  primaryClientId String?
  primaryClient   Client?        @relation(fields: [primaryClientId], references: [id])
  clientLinks     MatterClient[]

  ownerId String
  owner   User           @relation("MatterOwner", fields: [ownerId], references: [id])
  members MatterMember[]

  intakeId String? @unique
  intake   Intake? @relation(fields: [intakeId], references: [id])

  firstAcceptedAt DateTime?
  closedAt        DateTime?
  archivedAt      DateTime?

  procedures       MatterProcedure[]
  parties          Party[]
  relatedEntities  RelatedEntity[]
  notes            Note[]
  tasks            Task[]
  documents        Document[]
  timelineEvents   TimelineEvent[]
  billings         Billing[]
  feeEntries       FeeEntry[]
  commissionPlans  CommissionPlan[]
  archiveRecords   ArchiveRecord[]
  invoiceRequests  InvoiceRequest[]
  // v0.8: 卷宗 + 用章
  folders          DocumentFolder[]
  sealRequests     SealRequest[]
  // v0.9: 法院短信 + 财产保全 + 快递追踪
  smsMessages      SmsMessage[]
  preservations    Preservation[]
  expressTrackings ExpressTracking[]
  // v0.21: AI 文书审查历史
  reviewRecords    ReviewRecord[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status, updatedAt])
  @@index([ownerId])
  @@index([primaryClientId])
  @@index([category, status])
  @@index([causeId])
}

model MatterMember {
  matterId String
  matter   Matter           @relation(fields: [matterId], references: [id], onDelete: Cascade)
  userId   String
  user     User             @relation(fields: [userId], references: [id])
  role     MatterMemberRole @default(ASSISTANT)
  joinedAt DateTime         @default(now())

  @@id([matterId, userId])
  @@index([userId])
}

model MatterClient {
  matterId  String
  matter    Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  label     String?
  isPrimary Boolean  @default(false)
  addedAt   DateTime @default(now())

  @@id([matterId, clientId])
  @@index([clientId])
}

// ============================================================
// 程序阶段
// ============================================================

model MatterProcedure {
  id       String @id @default(cuid())
  matterId String
  matter   Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  type        ProcedureType
  customLabel String?
  engagement  ProcedureEngagement @default(ENGAGED)
  order       Int

  caseNumber     String?
  handlingAgency String?
  panel          String?
  handler        String?

  acceptedAt  DateTime?
  concludedAt DateTime?

  status      ProcedureStatus   @default(PENDING)
  outcome     ProcedureOutcome?
  outcomeNote String?

  stages    MatterStage[]
  hearings  Hearing[]
  deadlines Deadline[]
  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matterId, order])
  @@index([matterId, order])
  @@index([status])
}

model MatterStage {
  id          String          @id @default(cuid())
  procedureId String
  procedure   MatterProcedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  name        String
  description String?
  order       Int
  startedAt   DateTime?
  completedAt DateTime?
  tasks       Task[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([procedureId, order])
}

// ============================================================
// 任务 / 开庭 / 期限
// ============================================================

model Task {
  id          String       @id @default(cuid())
  matterId    String
  matter      Matter       @relation(fields: [matterId], references: [id], onDelete: Cascade)
  stageId     String?
  stage       MatterStage? @relation(fields: [stageId], references: [id])
  title       String
  description String?
  assigneeId  String?
  dueAt       DateTime?
  completed   Boolean      @default(false)
  completedAt DateTime?
  priority    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([matterId, completed, dueAt])
  @@index([assigneeId, completed])
}

model Hearing {
  id          String          @id @default(cuid())
  procedureId String
  procedure   MatterProcedure @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  title       String
  room        String?
  judge       String?
  startsAt    DateTime
  endsAt      DateTime?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([procedureId, startsAt])
  @@index([startsAt])
}

model Deadline {
  id          String           @id @default(cuid())
  procedureId String
  procedure   MatterProcedure  @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  title       String
  category    DeadlineCategory @default(CUSTOM)
  dueAt       DateTime
  basis       String?
  remindDays  Int              @default(3)
  completed   Boolean          @default(false)
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([procedureId, dueAt, completed])
  @@index([dueAt, completed])
}

// ============================================================
// 当事人 / 关联实体
// ============================================================

model Party {
  id        String              @id @default(cuid())
  intakeId  String?
  intake    Intake?             @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  matterId  String?
  matter    Matter?             @relation(fields: [matterId], references: [id], onDelete: Cascade)
  role      PartyRole
  // v0.5: 具体诉讼地位（依首程序联动），role 保留作粗粒度
  standing  LitigationStanding?
  ordinal   Int                 @default(1)
  name      String
  // v0.27: 主体类型决定必填字段分支（自然人 → idNumber；公司 → enterpriseSocialCode + legalRep + address）
  partyType PartyType           @default(NATURAL_PERSON)
  idNumber  String?
  phone     String?
  address   String?
  legalRep  String?
  // v0.27: 经办联系人（区别于 phone 当事人本人电话，常用于公司路径）
  contactName String?
  notes     String?
  // v0.26: 对方公司风险查询 — 绑定元典企业后，可一键拉取风险总览
  enterpriseId         String?
  enterpriseSocialCode String?
  enterpriseName       String?
  enterpriseBoundAt    DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([matterId, role, ordinal])
  @@index([name])
  @@index([idNumber])
  @@index([enterpriseSocialCode])
}

model RelatedEntity {
  id           String   @id @default(cuid())
  matterId     String
  matter       Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  name         String
  relationship String
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([name])
}

// ============================================================
// 冲突检索
// ============================================================

model ConflictCheck {
  id           String             @id @default(cuid())
  intakeId     String?
  intake       Intake?            @relation(fields: [intakeId], references: [id])
  queryPayload Json
  hits         ConflictHit[]
  conclusion   ConflictConclusion @default(PENDING)
  decidedById  String?
  decidedBy    User?              @relation("ConflictDecidedBy", fields: [decidedById], references: [id])
  decidedAt    DateTime?
  note         String?
  checkedAt    DateTime           @default(now())
}

model ConflictHit {
  id           String           @id @default(cuid())
  checkId      String
  check        ConflictCheck    @relation(fields: [checkId], references: [id], onDelete: Cascade)
  hitType      String
  targetType   String
  targetId     String
  matchedName  String
  matchedField String
  matchedValue String
  matchedRatio Float?
  severity     ConflictSeverity
  reason       String
}

// ============================================================
// 沟通记录
// ============================================================

model Note {
  id          String      @id @default(cuid())
  matterId    String
  matter      Matter      @relation(fields: [matterId], references: [id], onDelete: Cascade)
  authorId    String
  author      User        @relation("NoteAuthor", fields: [authorId], references: [id])
  channel     NoteChannel @default(OTHER)
  withWhom    String?
  occurredAt  DateTime    @default(now())
  content     String
  tags        String[]
  attachments String[]
  deletedAt   DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([matterId, occurredAt])
}

// ============================================================
// 材料（含加密支持）
// ============================================================

model Document {
  id          String           @id @default(cuid())
  // v0.4: matterId 可空（收案阶段挂在 Intake 上），转 Matter 时回填
  matterId    String?
  matter      Matter?          @relation(fields: [matterId], references: [id], onDelete: Cascade)
  intakeId    String?
  intake      Intake?          @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  procedureId String?
  procedure   MatterProcedure? @relation(fields: [procedureId], references: [id])
  name        String
  category    DocumentCategory @default(OTHER)
  // v0.10: 文书审批流程
  status      DocumentStatus   @default(DRAFT)
  reviewedById String?
  reviewedBy   User?            @relation("DocumentReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  approvedById String?
  approvedBy   User?            @relation("DocumentApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  version     Int              @default(1)
  isLatest    Boolean          @default(true)
  familyId    String?

  path     String
  mimeType String?
  size     Int?
  sha256   String?

  encrypted Boolean @default(false)
  algorithm String?
  iv        String?
  authTag   String?

  tags         String[]
  uploadedById String
  uploadedBy   User      @relation("DocumentUploader", fields: [uploadedById], references: [id])
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // v0.5: 发票工作流附件反向
  invoiceAsContract InvoiceRequest? @relation("InvoiceContractScan")
  invoiceAsFile     InvoiceRequest? @relation("InvoiceFile")

  // v0.8: 卷宗归属 + 模板生成
  folderId                String?
  folder                  DocumentFolder?   @relation(fields: [folderId], references: [id])
  templateId              String?
  template                DocumentTemplate? @relation("TemplateGenerated", fields: [templateId], references: [id])
  templateContextSnapshot Json?
  // v0.8: 反向 - 作为某模板的源 docx
  templateBlobOf          DocumentTemplate? @relation("TemplateBlob")
  // v0.8: 反向 - 作为用章申请的待盖章稿 / 盖章后扫描件
  sealAsDraft             SealRequest?      @relation("SealDraft")
  sealAsStamped           SealRequest?      @relation("SealStamped")

  // v0.17: 归档清单关联——上传时绑定到 ArchiveChecklistItem.id（lib/archive/checklists.ts 内的字符串 id），
  // 用于归档向导自动勾选已上传的必交项。一个材料只能绑定一个 checklist item。
  archiveChecklistItemId String?

  // v0.21: 反向 - AI 审查历史
  reviewRecords ReviewRecord[]

  @@index([matterId, category])
  @@index([intakeId])
  @@index([procedureId])
  @@index([familyId])
  @@index([folderId])
  @@index([templateId])
  @@index([matterId, archiveChecklistItemId])
}

// ============================================================
// 发票申请工作流（v0.5）
// 律师在案件详情提交申请 → 财务审核 → 上传扫描件合同 + 电子发票
// ============================================================

model InvoiceRequest {
  id          String               @id @default(cuid())
  matterId    String
  matter      Matter               @relation(fields: [matterId], references: [id], onDelete: Cascade)
  amount      Decimal              @db.Decimal(14, 2)
  title       String? // 备注 / 客户称谓（仅做兼容，新字段用 buyerName）
  status      InvoiceRequestStatus @default(PENDING)
  requestNote String?

  // v0.12: 开票类型 + 名目 + 抬头 + 税号 + 开票依据
  invoiceType    InvoiceType?
  invoiceItem    InvoiceItem?
  buyerName      String? // 开票抬头（客户名，可编辑）
  buyerTaxNo     String? // 客户税号（专票必填）
  evidenceDocIds String[] @default([]) // 开票依据 Document id 列表

  // v0.14: 真实发票号（财务开票完成时回填）
  invoiceNo String?
  issuedAt  DateTime?

  requestedById String
  requestedBy   User     @relation("InvoiceRequester", fields: [requestedById], references: [id])
  requestedAt   DateTime @default(now())

  processedById String?
  processedBy   User?     @relation("InvoiceProcessor", fields: [processedById], references: [id])
  processedAt   DateTime?
  processNote   String?

  // 财务上传：扫描件合同 + 电子发票文件（均走 Document）
  contractScanId String?   @unique
  contractScan   Document? @relation("InvoiceContractScan", fields: [contractScanId], references: [id])
  invoiceFileId  String?   @unique
  invoiceFile    Document? @relation("InvoiceFile", fields: [invoiceFileId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matterId, status])
  @@index([status, requestedAt])
  @@index([requestedById])
}

// ============================================================
// 财务：合同 / 收付 / 分成
// ============================================================

model Billing {
  id             String        @id @default(cuid())
  matterId       String
  matter         Matter        @relation(fields: [matterId], references: [id], onDelete: Cascade)
  title          String
  contractAmount Decimal       @db.Decimal(14, 2)
  schedule       String?
  status         BillingStatus @default(DRAFT)
  signedAt       DateTime?
  feeEntries     FeeEntry[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([matterId, status])
}

model FeeEntry {
  id           String       @id @default(cuid())
  matterId     String
  matter       Matter       @relation(fields: [matterId], references: [id], onDelete: Cascade)
  billingId    String?
  billing      Billing?     @relation(fields: [billingId], references: [id])
  type         FeeEntryType
  amount       Decimal      @db.Decimal(14, 2)
  occurredAt   DateTime     @default(now())
  invoiceNo    String?
  invoiceFile  String?
  payerOrPayee String?
  method       String?
  note         String?

  parentFeeEntryId   String?
  parentFeeEntry     FeeEntry?  @relation("CommissionParent", fields: [parentFeeEntryId], references: [id])
  commissionChildren FeeEntry[] @relation("CommissionParent")

  beneficiaryUserId String?
  beneficiaryUser   User?   @relation("FeeBeneficiary", fields: [beneficiaryUserId], references: [id])

  recordedById String
  recordedBy   User   @relation("FeeRecorder", fields: [recordedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matterId, type, occurredAt])
  @@index([type, occurredAt])
  @@index([beneficiaryUserId, occurredAt])
}

model CommissionPlan {
  id        String   @id @default(cuid())
  matterId  String
  matter    Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  percent   Decimal  @db.Decimal(5, 2)
  label     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matterId, userId])
  @@index([matterId])
  @@index([userId])
}

// ============================================================
// 时间线 / 归档 / 审计
// ============================================================

model TimelineEvent {
  id         String   @id @default(cuid())
  matterId   String
  matter     Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  eventType  String
  title      String
  content    String?
  occurredAt DateTime
  refType    String?
  refId      String?
  createdAt  DateTime @default(now())

  @@index([matterId, occurredAt])
}

enum ArchiveStatus {
  PENDING_REVIEW // 归档申请已提交，等管理员审批
  APPROVED // 已审批通过，正式归档
  REJECTED // 管理员驳回
}

model ArchiveRecord {
  id       String @id @default(cuid())
  matterId String
  matter   Matter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  archiveNo       String               @unique
  summary         String
  judgmentSummary String?
  closedReason    ArchiveClosedReason?
  completedAt     DateTime?
  checklistJson   Json
  missingItems    String[]

  coverDocId   String?
  catalogDocId String?

  archivedBy   String  // 申请人姓名快照（兼容历史，不删）
  archivedById String? // v0.18: 申请人 User.id，用于审批通知路由
  archivedAt   DateTime @default(now())
  exportPath   String?
  checksum     String?

  // v0.16: 归档审批流
  status       ArchiveStatus @default(PENDING_REVIEW)
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?

  @@index([matterId])
  @@index([archivedAt])
  @@index([status])
  @@index([archivedById, status])
}

enum ArchiveClosedReason {
  JUDGMENT
  MEDIATION
  WITHDRAWAL
  SETTLEMENT
  RULING
  OTHER
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String
  targetType String?
  targetId   String?
  detail     Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// ============================================================
// 系统配置
// ============================================================

model StageTemplate {
  id            String        @id @default(cuid())
  procedureType ProcedureType
  isDefault     Boolean       @default(true)
  name          String
  steps         Json
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([procedureType])
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ============================================================
// v0.8: 文档模板系统
// ============================================================

// 模板定义（系统/律所级，不属于具体 Matter）
model DocumentTemplate {
  id                   String           @id @default(cuid())
  name                 String
  category             TemplateCategory
  description          String?
  applicableCategories MatterCategory[] // 空数组 = 适用全部案件类别
  docxBlobId           String           @unique
  docxBlob             Document         @relation("TemplateBlob", fields: [docxBlobId], references: [id])
  variables            Json // 变量清单 ["client.name", "matter.caseNumber", ...] 用于缺失提示
  isBuiltIn            Boolean          @default(false) // 系统内置不可删
  enabled              Boolean          @default(true)
  createdById          String?
  createdBy            User?            @relation("TemplateCreator", fields: [createdById], references: [id])
  generatedDocs        Document[]       @relation("TemplateGenerated")
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@index([category, enabled])
  @@index([isBuiltIn])
}

// 卷宗（每个 Matter 内的物理归档目录）
model DocumentFolder {
  id         String     @id @default(cuid())
  matterId   String
  matter     Matter     @relation(fields: [matterId], references: [id], onDelete: Cascade)
  name       String
  orderIndex Int        @default(0)
  isDefault  Boolean    @default(false) // 系统按案件类别预置（可改名不可删）
  documents  Document[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([matterId, name])
  @@index([matterId, orderIndex])
}

// ============================================================
// v0.8: 用章审批工作流
// ============================================================

// 章种类配置（决策 §12.9.2：approverRoles: Role[] 多角色 OR 关系）
model SealTypeConfig {
  type             SealType   @id
  label            String // 中文显示名
  description      String?
  approverRoles    UserRole[] // 多角色 OR 关系；空数组 = 仅 requiresLegalRep 生效
  requiresLegalRep Boolean    @default(false) // 必须法定代表人本人审批（取 SystemSetting key=firmLegalRepUserId）
  enabled          Boolean    @default(true)
  updatedAt        DateTime   @updatedAt
}

// 用章申请
model SealRequest {
  id       String   @id @default(cuid())
  code     String   @unique // SEAL-2026-0001
  sealType SealType
  matterId String?
  matter   Matter?  @relation(fields: [matterId], references: [id])

  purpose              String // 用章事由
  documentTitle        String // 待盖章文件标题
  pageCount            Int     @default(1)
  requireCrossPageSeal Boolean @default(false)
  copies               Int     @default(1)
  urgency              Urgency @default(NORMAL)

  // 待盖章稿（必传） + 盖章后扫描件（盖章完成时必补）
  draftDocId   String    @unique
  draftDoc     Document  @relation("SealDraft", fields: [draftDocId], references: [id])
  stampedDocId String?   @unique
  stampedDoc   Document? @relation("SealStamped", fields: [stampedDocId], references: [id])

  status      SealRequestStatus @default(PENDING)
  requestNote String?
  approveNote String?

  requestedById String
  requestedBy   User     @relation("SealRequester", fields: [requestedById], references: [id])
  requestedAt   DateTime @default(now())

  approvedById String?
  approvedBy   User?     @relation("SealApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  stampedById   String?
  stampedByUser User?     @relation("SealStamper", fields: [stampedById], references: [id])
  stampedAt     DateTime?

  rejectedAt DateTime?

  // 被驳回后重新申请的溯源链（旧 → 新）
  parentSealRequestId String?
  parentSealRequest   SealRequest?  @relation("SealResubmission", fields: [parentSealRequestId], references: [id])
  resubmissions       SealRequest[] @relation("SealResubmission")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, requestedAt])
  @@index([requestedById, status])
  @@index([sealType, status])
  @@index([matterId])
}

// ============================================================
// v0.9: 法院短信收件箱
// ============================================================

// 短信类型（与旧系统 SMS_TYPE_KEYWORDS 对齐）
enum SmsType {
  HEARING_NOTICE // 开庭通知
  SERVICE_NOTICE // 送达通知
  FEE_NOTICE // 缴费通知
  MEDIATION // 调解通知
  ENFORCEMENT // 执行通知
  FILING_NOTICE // 立案通知
  JUDGMENT_NOTICE // 判决通知
  EVIDENCE_SUBMIT // 提交材料 / 举证
  OTHER
}

// 与 Matter 的匹配来源
enum SmsMatchSource {
  AUTO_CASE_NUMBER // 按案号自动匹配
  MANUAL // 用户手动指派
  UNMATCHED
}

model SmsMessage {
  id           String   @id @default(cuid())
  rawText      String // 原始短信全文
  receivedAt   DateTime @default(now())
  receivedById String
  receivedBy   User     @relation("SmsReceiver", fields: [receivedById], references: [id], onDelete: Restrict)

  // 解析结果（含 caseNumbers / court / hearingDate / urls / judge / clerk / phones ...）
  parsedJson Json
  smsType    SmsType @default(OTHER)

  // 关联匹配
  matchedMatterId String?
  matchedMatter   Matter?        @relation(fields: [matchedMatterId], references: [id], onDelete: SetNull)
  matchedBy       SmsMatchSource @default(UNMATCHED)

  // 一键生成动作的产物 id（追溯）
  generatedHearingId  String?
  generatedDeadlineId String?

  processed   Boolean   @default(false)
  processedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([receivedById, processed, receivedAt])
  @@index([matchedMatterId])
  @@index([smsType, receivedAt])
}

// ============================================================
// v0.9: 财产保全
// ============================================================

enum PreservationType {
  PRE_LITIGATION // 诉前保全
  LITIGATION // 诉中保全
  ENFORCEMENT // 执行保全
}

enum PropertyType {
  BANK_DEPOSIT // 银行存款
  REAL_ESTATE // 房产
  VEHICLE // 车辆
  EQUITY // 股权
  IP // 知识产权
  OTHER // 其他财产
}

enum GuaranteeType {
  CASH_DEPOSIT // 保证金
  GUARANTEE_LETTER // 保函
  PROPERTY // 财产担保
  NONE // 无需担保
}

enum PreservationStatus {
  ACTIVE // 生效中
  RENEWED // 已续保
  EXPIRED // 已到期
  LIFTED // 已解除
}

model Preservation {
  id       String  @id @default(cuid())
  // 诉前保全可空（决策 §13.8.3）；立案后回填 matterId
  matterId String?
  matter   Matter? @relation(fields: [matterId], references: [id], onDelete: SetNull)

  type          PreservationType
  propertyType  PropertyType
  amount        Decimal?         @db.Decimal(18, 2)
  respondent    String // 被保全人
  guaranteeType GuaranteeType?

  appliedAt  DateTime? // 申请日
  startDate  DateTime // 生效日（必填）
  duration   Int // 保全期限（天）；默认按 propertyType 推荐
  expiryDate DateTime // 到期日 = startDate + duration（可手动覆盖）

  court          String?
  rulingNumber   String?
  propertyDetail String?
  note           String?

  ownerId String?
  owner   User?   @relation("PreservationOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  // 提醒阈值（天）默认 [30, 15, 7, 3, 1]
  remindDays Int[]                 @default([30, 15, 7, 3, 1])
  status     PreservationStatus    @default(ACTIVE)
  renewals   PreservationRenewal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matterId])
  @@index([status, expiryDate])
  @@index([ownerId, status])
}

model PreservationRenewal {
  id             String       @id @default(cuid())
  preservationId String
  preservation   Preservation @relation(fields: [preservationId], references: [id], onDelete: Cascade)

  renewedAt       DateTime
  oldExpiryDate   DateTime
  newExpiryDate   DateTime
  renewalDuration Int // 新增的天数
  note            String?

  performedById String
  performedBy   User     @relation("RenewalPerformer", fields: [performedById], references: [id], onDelete: Restrict)
  createdAt     DateTime @default(now())

  @@index([preservationId])
}

// ============================================================
// v0.9.3: 快递追踪
// ============================================================

enum ExpressDirection {
  OUTBOUND // 寄出（律所 → 法院 / 当事人 / 对方）
  INBOUND // 收到（法院 / 当事人 → 律所）
}

model ExpressTracking {
  id             String           @id @default(cuid())
  matterId       String?
  matter         Matter?          @relation(fields: [matterId], references: [id], onDelete: SetNull)
  trackingNo     String
  companyCode    String? // 中文公司名（顺丰速运 / 中通快递 等）
  direction      ExpressDirection
  purpose        String // 用途（如：起诉状寄朝阳法院 / 法院送达判决书）
  recipient      String? // 收件人/单位
  recipientPhone String?

  lastState    String? // 揽件 / 在途 / 到达派件 / 已签收 / 退签 / 疑难
  lastUpdateAt DateTime?
  tracesJson   Json? // 完整轨迹快照（旧次刷新覆盖；不入历史）

  createdById String
  createdBy   User     @relation("ExpressCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([matterId])
  @@index([trackingNo])
  @@index([createdById, createdAt])
}

// ============================================================
// v0.10: 通知系统
// ============================================================

enum NotificationType {
  PRESERVATION_EXPIRY
  HEARING_REMINDER
  DEADLINE_REMINDER
  SEAL_STATUS_CHANGE
  SMS_ARRIVAL
  TASK_ASSIGNED
  SYSTEM
  // v0.18: 归档审批通知
  ARCHIVE_APPROVED
  ARCHIVE_REJECTED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Notification {
  id         String               @id @default(cuid())
  userId     String
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  priority   NotificationPriority @default(NORMAL)
  title      String
  content    String?
  href       String?
  refType    String?
  refId      String?
  read       Boolean              @default(false)
  readAt     DateTime?
  createdAt  DateTime             @default(now())

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
}

// v0.21: AI 文书审查历史
// 每次点「AI 审查」+ 拿到结果都会写一条；按 document/matter 反查能拿全部历史
model ReviewRecord {
  id           String   @id @default(cuid())
  matterId     String
  matter       Matter   @relation(fields: [matterId], references: [id], onDelete: Cascade)
  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  reviewedById String
  reviewedBy   User     @relation("ReviewAuthor", fields: [reviewedById], references: [id])
  reviewedAt   DateTime @default(now())

  itemCount         Int
  itemsJson         Json    // ReviewItem[]
  textPreviewChars  Int
  truncated         Boolean @default(false)

  @@index([documentId, reviewedAt])
  @@index([matterId, reviewedAt])
}

// v0.22: 律所级资料库（与案件无关）
// 制度 / 指引 / 参考模板（不同于 v0.8 生成型 DocumentTemplate）/ 其他文件
enum FirmFileCategory {
  POLICY     // 制度（员工手册、保密协议、薪酬制度等）
  GUIDE      // 指引（办案指引、客户接待指引等）
  TEMPLATE   // 参考模板（律师下载手动改的样本，区别于 docxtemplater 生成型）
  REFERENCE  // 其他文件（营业执照、执业证扫描件等）
}

model FirmFile {
  id          String           @id @default(cuid())
  name        String
  description String?
  category    FirmFileCategory
  tags        String[]

  path     String
  mimeType String?
  size     Int
  sha256   String?

  uploadedById String
  uploadedBy   User   @relation("FirmFileUploader", fields: [uploadedById], references: [id])

  // 旧版被新版替代时，旧版指向新版 id；列表默认隐藏被替代的
  supersededById String?
  supersededBy   FirmFile?  @relation("FirmFileSupersedes", fields: [supersededById], references: [id])
  supersedes     FirmFile[] @relation("FirmFileSupersedes")

  archivedAt DateTime? // soft delete
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([category, archivedAt, createdAt])
  @@index([supersededById])
}

// v0.27: 服务中心 —— 律所公告（独立 Model，pinned 公告作顶部 banner）
model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  pinned      Boolean  @default(false)
  publishedAt DateTime @default(now())
  // 到期后 banner 不再显示；列表仍保留
  expiresAt   DateTime?
  authorId    String
  author      User     @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  archivedAt  DateTime? // soft delete
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([pinned, archivedAt, publishedAt])
  @@index([authorId, createdAt])
}

// v0.27: 服务中心 —— 外部联系人（法院 / 公证 / 他所律师 等）
enum ExternalContactCategory {
  COURT       // 法院
  PROSECUTOR  // 检察院
  POLICE      // 公安
  NOTARY      // 公证处
  ARBITRATION // 仲裁机构
  OTHER_FIRM  // 他所律师
  EXPERT      // 鉴定 / 评估专家
  OTHER       // 其他
}

model ExternalContact {
  id           String                  @id @default(cuid())
  name         String
  category     ExternalContactCategory
  organization String?
  title        String?
  phone        String?
  email        String?
  wechat       String?
  address      String?
  notes        String?
  tags         String[]

  createdById  String
  createdBy    User     @relation("ExternalContactCreator", fields: [createdById], references: [id])
  archivedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category, archivedAt, name])
  @@index([name])
}
